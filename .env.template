# Google Maps API Configuration
# Required for MapView component to load Google Maps via proxy
VITE_FRONTEND_FORGE_API_KEY=your_google_maps_api_key_here

# Optional: Forge proxy URL
# Defaults to https://forge.butterfly-effect.dev if not set
# VITE_FRONTEND_FORGE_API_URL=https://forge.butterfly-effect.dev

# Optional: Umami Analytics
# Uncomment and set these to enable analytics tracking
# VITE_ANALYTICS_ENDPOINT=https://analytics.example.com
# VITE_ANALYTICS_WEBSITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
